<Window x:Class="BookStore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BookStore.Converters"
        Title="ЧитайГород - Список товаров" Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        Icon="Res/icon.ico">
    <Window.Resources>
        <!-- Подключаем наши конвертеры -->
        <local:ProductBackgroundConverter x:Key="ProductBackgroundConverter"/>
        <local:ImagePathConverter x:Key="ImagePathConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <!-- Шапка -->
            <RowDefinition Height="Auto"/>
            <!-- Панель инструментов -->
            <RowDefinition Height="*"/>
            <!-- Список товаров -->
        </Grid.RowDefinitions>

        <!-- 1. ШАПКА (Логотип, ФИО, Кнопка выхода) -->
        <Grid Grid.Row="0" Background="{StaticResource SecondaryBackground}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15">
                <Image Source="Resources/logo.png" Height="60" Margin="0,0,15,0"/>
                <TextBlock Text="ЧитайГород" FontSize="26" FontWeight="Bold" Foreground="{StaticResource AccentColor}" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock x:Name="TxtUserInfo" Grid.Column="1" VerticalAlignment="Center" FontSize="16" Margin="15" Foreground="{StaticResource AccentColor}" FontWeight="SemiBold"/>

            <Button x:Name="BtnLogout" Grid.Column="2" Content="Выйти" Click="BtnLogout_Click" Margin="15" Padding="20,10"/>
        </Grid>

        <!-- 2. ПАНЕЛЬ ИНСТРУМЕНТОВ (Скрывается для Гостя и Клиента) -->
        <StackPanel x:Name="PanelTools" Grid.Row="1" Orientation="Horizontal" Margin="15,10" Visibility="Collapsed">
            <TextBox x:Name="TxtSearch" Width="280" Height="35" FontSize="16" TextChanged="TxtSearch_TextChanged">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="🔍 Поиск по названию, артикулу..." Foreground="Gray" Margin="10,0,0,0"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <ComboBox x:Name="CmbSort" Width="180" SelectionChanged="CmbSort_SelectionChanged">
                <ComboBoxItem Content="Сортировка: Нет" IsSelected="True"/>
                <ComboBoxItem Content="Цена ↑"/>
                <ComboBoxItem Content="Цена ↓"/>
                <ComboBoxItem Content="Остаток ↑"/>
                <ComboBoxItem Content="Остаток ↓"/>
            </ComboBox>

            <ComboBox x:Name="CmbFilter" Width="200" SelectionChanged="CmbFilter_SelectionChanged">
                <ComboBoxItem Content="Все диапазоны" IsSelected="True"/>
                <ComboBoxItem Content="0 - 12,99%"/>
                <ComboBoxItem Content="13 - 16,99%"/>
                <ComboBoxItem Content="17% и более"/>
            </ComboBox>
            <Button x:Name="BtnOrders" Content="📦 Заказы" Click="BtnOrders_Click" Margin="10,0,0,0" Visibility="Collapsed"/>
            <Button x:Name="BtnAddProduct" Content="➕ Добавить товар" Visibility="Collapsed" Click="BtnAddProduct_Click" Margin="15,0,0,0"/>
        </StackPanel>

        <!-- 3. СПИСОК ТОВАРОВ -->
        <ListView x:Name="LstProducts" Grid.Row="2" Margin="10" MouseDoubleClick="LstProducts_MouseDoubleClick" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Margin" Value="5"/>
                    <Setter Property="Padding" Value="5"/>
                    <Setter Property="BorderBrush" Value="LightGray"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <!-- Подсветка строк (Серый если нет на складе, Голубой если скидка > 25%) -->
                    <Setter Property="Background">
                        <Setter.Value>
                            <MultiBinding Converter="{StaticResource ProductBackgroundConverter}">
                                <Binding Path="AmountInStock"/>
                                <Binding Path="Discount"/>
                            </MultiBinding>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>

                        <!-- Фото товара -->
                        <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="1">
                            <Image Stretch="Uniform"
                                    Source="{Binding Photo, Converter={StaticResource ImagePathConverter}}"/>
                        </Border>

                        <!-- Текстовая информация -->
                        <StackPanel Grid.Column="1" Margin="15,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Article, StringFormat='Артикул: {0}'}" Foreground="Gray" FontSize="12"/>
                                <TextBlock Text=" | " Foreground="Gray" FontSize="12"/>
                                <!-- Внимание: если EF сгенерировал Category1, замени Category на Category1 -->
                                <TextBlock Text="{Binding Category.Name}" Foreground="Gray" FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>

                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" TextWrapping="Wrap" Margin="0,5,0,0"/>
                            <TextBlock Text="{Binding Description}" Foreground="DarkGray" TextWrapping="Wrap" FontSize="13" Margin="0,2,0,0" MaxHeight="40"/>

                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <TextBlock Text="Производитель: " FontSize="12"/>
                                <TextBlock Text="{Binding Producer.Name}" FontWeight="SemiBold" FontSize="12"/>
                                <TextBlock Text=" | Поставщик: " Margin="10,0,0,0" FontSize="12"/>
                                <TextBlock Text="{Binding Provider.Name}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Цена и Наличие -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <!-- Старая зачеркнутая цена -->
                                <TextBlock Text="{Binding Price, StringFormat={}{0:N2} ₽}" 
                                           Foreground="Red" TextDecorations="Strikethrough" FontSize="14"
                                           Visibility="{Binding IsDiscounted, Converter={StaticResource BoolToVis}}"/>
                                <!-- Итоговая цена -->
                                <TextBlock Text="{Binding FinalPrice, StringFormat={}{0:N2} ₽}" 
                                           Foreground="Black" FontWeight="Bold" FontSize="18" Margin="5,0,0,0"/>
                            </StackPanel>

                            <TextBlock HorizontalAlignment="Right" Margin="0,5,0,0" FontSize="13">
                                <Run Text="На складе: "/>
                                <Run Text="{Binding AmountInStock, Mode=OneWay}"/>
                                <Run Text=" шт."/>
                            </TextBlock>

                            <TextBlock Text="{Binding Discount, StringFormat='Скидка: {0}%'}" 
                                       Foreground="DarkCyan" FontWeight="SemiBold" HorizontalAlignment="Right"
                                       Visibility="{Binding IsDiscounted, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>