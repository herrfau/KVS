<Window x:Class="BookStore.OrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ЧитайГород - Заказы" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Icon="Res/icon.ico">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Image Source="Res/icon.png" Height="45" Margin="0,0,10,0"/>
            <TextBlock Text="Список заказов" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentColor}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Фильтр по статусу -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10">
            <TextBlock Text="Статус заказа:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
            <ComboBox x:Name="CmbStatusFilter" Width="200" SelectionChanged="CmbStatusFilter_SelectionChanged">
                <ComboBoxItem Content="Все статусы" IsSelected="True"/>
            </ComboBox>
        </StackPanel>

        <!-- Таблица заказов -->
        <DataGrid x:Name="DgOrders" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" 
                  CanUserAddRows="False" CanUserDeleteRows="False" Margin="0,10"
                  FontFamily="Comic Sans MS" FontSize="14" RowHeight="35" AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№ Заказа" Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn Header="Дата создания" Binding="{Binding CreationDate, StringFormat=dd.MM.yyyy}" Width="120"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="180"/>
                <DataGridTextColumn Header="Пункт выдачи" Binding="{Binding PickUpPointAddress}" Width="200"/>
                <DataGridTextColumn Header="Код получения" Binding="{Binding ReceiptCode}" Width="110"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="120"/>
                <DataGridTextColumn Header="Дата доставки" Binding="{Binding DeliveryDate, StringFormat=dd.MM.yyyy, TargetNullValue='-'}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnBack" Content="↩ Назад к товарам" Click="BtnBack_Click" Width="180"/>
        </StackPanel>
    </Grid>
</Window>