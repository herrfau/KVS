<Window x:Class="BookStore.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BookStore.Converters"
        Title="Карточка товара" Height="700" Width="550"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Icon="Res/icon.ico">
    <Window.Resources>
        <local:ImagePathConverter x:Key="ImagePathConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. Заголовок с ID -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="ID товара: " FontWeight="Bold" VerticalAlignment="Center" FontSize="16"/>
            <TextBox x:Name="TxtId" Width="100" IsReadOnly="True" Background="#F0F0F0" Visibility="Collapsed" FontSize="16"/>
            <TextBlock x:Name="TxtIdPlaceholder" Text="Сгенерируется автоматически" Foreground="Gray" VerticalAlignment="Center" FontStyle="Italic"/>
        </StackPanel>

        <!-- 2. Основная форма с прокруткой -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Блок фото -->
                <Border BorderBrush="LightGray" BorderThickness="1" Width="300" Height="200" HorizontalAlignment="Center" Margin="0,0,0,10" Background="#FAFAFA">
                    <Image x:Name="ImgProduct" Stretch="Uniform"
                           Source="{Binding Photo, Converter={StaticResource ImagePathConverter}}"/>
                </Border>
                <Button x:Name="BtnUploadPhoto" Content="📷 Загрузить / Заменить фото" Click="BtnUploadPhoto_Click" HorizontalAlignment="Center" Margin="0,0,0,20" Width="250"/>

                <!-- Текстовые поля -->
                <TextBlock Text="Артикул *" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtArticle" MaxLength="10"/>

                <TextBlock Text="Наименование *" FontWeight="SemiBold" Margin="0,10,0,0"/>
                <TextBox x:Name="TxtName"/>

                <TextBlock Text="Описание" FontWeight="SemiBold" Margin="0,10,0,0"/>
                <TextBox x:Name="TxtDescription" Height="70" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                <!-- Выпадающие списки -->
                <Grid Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                        <TextBlock Text="Категория *" FontWeight="SemiBold"/>
                        <ComboBox x:Name="CmbCategory" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,10">
                        <TextBlock Text="Производитель *" FontWeight="SemiBold"/>
                        <ComboBox x:Name="CmbProducer" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Поставщик *" FontWeight="SemiBold"/>
                        <ComboBox x:Name="CmbProvider" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Ед. измерения *" FontWeight="SemiBold"/>
                        <ComboBox x:Name="CmbUnit" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    </StackPanel>
                </Grid>

                <!-- Числовые поля -->
                <Grid Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Цена (₽) *" FontWeight="SemiBold"/>
                        <TextBox x:Name="TxtPrice"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,5,0">
                        <TextBlock Text="На складе *" FontWeight="SemiBold"/>
                        <TextBox x:Name="TxtStock"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="5,0,0,0">
                        <TextBlock Text="Скидка (%)" FontWeight="SemiBold"/>
                        <TextBox x:Name="TxtDiscount"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- 3. Кнопки управления -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="BtnSave" Content="💾 Сохранить" Width="130" Click="BtnSave_Click"/>
            <Button x:Name="BtnDelete" Content="🗑 Удалить" Width="130" Background="#FFCDD2" Foreground="Black" Click="BtnDelete_Click" Visibility="Collapsed" Margin="10,0"/>
            <Button x:Name="BtnBack" Content="↩ Назад" Width="130" Click="BtnBack_Click"/>
        </StackPanel>
    </Grid>
</Window>